    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "commander": "^14.0.3",
    "execa": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/navegar-sistemas/vibe-sandbox.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/navegar-sistemas/vibe-sandbox#readme",
  "bugs": {
    "url": "https://github.com/navegar-sistemas/vibe-sandbox/issues"
  },
  "keywords": [
    "docker",
