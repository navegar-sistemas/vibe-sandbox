# Tell GitHub Linguist how to classify the CLI's `.tpl` template files.
# Without this, Linguist defaults `.tpl` to Smarty (a PHP template engine
# unrelated to this project). The files are plain Dockerfile/YAML used by
# the CLI's renderer; classify them as such so the language stats reflect
# what the repository actually contains.
cli/templates/Dockerfile*.tpl              linguist-language=Dockerfile
cli/templates/docker-compose*.yml.tpl      linguist-language=YAML

# The CLI build artefacts are gitignored; if any slip in, exclude from stats.
cli/dist/**                                linguist-generated=true
