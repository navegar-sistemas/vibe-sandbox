# Default owner for everything in the repo.
# Lines starting with '#' are comments. Order matters — last matching pattern wins.

* @navegar-sistemas

# Workflows and CI configuration require extra scrutiny.
/.github/workflows/   @navegar-sistemas
/.github/dependabot.yml @navegar-sistemas

# Hardened base files — changes here affect every user of the template.
/Dockerfile.sandbox            @navegar-sistemas
/docker-compose.sandbox.yml    @navegar-sistemas

# AI-governance surfaces — files that define how a Claude Code agent is
# allowed to act in this repository. Because these files are editable by
# the agent itself, owner review is the load-bearing defense. See
# SECURITY.md "Threat model boundary".
/.claude/CLAUDE.md             @navegar-sistemas
/.claude/agents/               @navegar-sistemas
/.claude/commands/             @navegar-sistemas
/.claude/hooks/                @navegar-sistemas
/.claude/settings.json         @navegar-sistemas

# Lint and validation configuration — relaxing these silently undermines
# the warnings-as-errors rule declared in .claude/CLAUDE.md.
/.hadolint.yaml                @navegar-sistemas
/.markdownlint.jsonc           @navegar-sistemas
/.editorconfig                 @navegar-sistemas

# CLI package surfaces. Templates render directly into containers that
# downstream users execute; package.json controls the dependency graph
# that lands on every user's machine; the build config decides what is
# bundled. All require explicit owner review.
/package/package.json              @navegar-sistemas
/package/package-lock.json         @navegar-sistemas
/package/tsup.config.ts            @navegar-sistemas
/package/tsconfig.json             @navegar-sistemas
/package/templates/                @navegar-sistemas
/package/src/                      @navegar-sistemas
